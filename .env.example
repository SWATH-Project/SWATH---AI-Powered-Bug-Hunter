# ══════════════════════════════════════════════════════════════
# SWATH — Environment Variables Template
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# SWATH auto-loads .env on every run — no manual exporting.
# ══════════════════════════════════════════════════════════════

# --- AI (OpenRouter — cloud LLM via API) ---
OPENROUTER_API_KEY="sk-or-v1-YOUR_KEY_HERE"
OPENROUTER_MODEL="google/gemini-2.5-flash"
OPENROUTER_API_URL="https://openrouter.ai/api/v1/chat/completions"

# --- GitHub Token (optional, for trufflehog/gitleaks) ---
GITHUB_TOKEN=""

# --- WPScan (optional, for WordPress scanning) ---
WPSCAN_API_TOKEN=""
